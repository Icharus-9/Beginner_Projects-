#include<iostream>
using namespace std;
#include<vector>

double getValidDouble(){
    double y;
    while(true){
        cin >> y;
        if(cin.fail()){
            cin.clear();
            cin.ignore(1000,'\n');
            cout << "Number grade expected: ";
        }else{break;
            
        }
    }return y;
}
string getValidString(){
    string x;
    while(true){
        cin >> x;
        if(cin.fail()){
        cin.clear();
        cin.ignore(1000,'\n');
        cout << "Invalid entry, names expected: "; 
    } else{
        break;
    }
        
    }
    return x;
}

struct Student{
  string name;
  double grade;
};

Student gatherStudentData(){
    cout << "Enter student name: ";
    string name;
    name = getValidString();
    cout << "Enter in student grade: ";
    double grade;
    grade = getValidDouble();
    Student s;
    s.name=name;
    s.grade=grade;
    return s;
}

void printStudents(Student s){
    cout << s.name <<":" << s.grade << endl;
    
}
double calcMin(vector<Student> students){
    double min = 999;
    for(Student s : students){
        if(s.grade < min){
            min = s.grade;
        }
    }return min;
}
double calcMax(vector<Student> students){
    double max = 0;
    for(Student s : students){
        if(s.grade > max){
            max = s.grade;
        }
    }return max;
}

double calcAverage(vector<Student> students){
    double total = 0;
    for(Student s : students){
        total = total + s.grade;
    }
    return total / students.size();
}
void printStudentInfo(vector<Student> students){
    cout << "--------------------" << endl;
    for(Student s : students){
        
        printStudents(s);
        
    }
    cout << "--------------------" << endl;
    cout << "Student Average: " << calcAverage(students) << endl;
    cout << "Highest Grade: " << calcMax(students) << endl;
    cout << "Lowest Grade: " << calcMin(students) << endl;
}
int main(){
    vector<Student> students;
    string action = "Yes";

    while(action == "Yes"){
        Student s = gatherStudentData();
        students.push_back(s);

        action = "";
        while(action != "Yes" && action != "No"){
            cout << "Would you like to add another student? (Yes/No): ";
            cin >> action;
            if(action != "Yes" && action != "No"){
                cout << "Please enter 'Yes' or 'No' only." << endl;
            }
        }
    }
    printStudentInfo(students);
    return 0;
}
