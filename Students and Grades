#include<iostream>
using namespace std;
#include<vector>

double getValidDouble(){
    double y;
    while(true){
        cin >> y;
        if(cin.fail()){
            cin.clear();
            cin.ignore(1000,'\n');
            cout << "Number grade expected: ";
        }else{break;
            
        }
    }return y;
}
string getValidString(){
    string x;
    while(true){
        cin >> x;
        if(cin.fail()){
        cin.clear();
        cin.ignore(1000,'\n');
        cout << "Invalid entry, names expected: "; 
    } else{
        break;
    }
        
    }
    return x;
}

struct Student{
  string name;
  double grade;
};

Student gatherStudentData(){
    cout << "Enter student name: ";
    string name;
    name = getValidString();
    cout << "Enter in student grade ";
    double grade;
    grade = getValidDouble();
    Student s;
    s.name=name;
    s.grade=grade;
    return s;
}

void printStudents(Student s){
    cout << s.name << endl;
    cout << s.grade << endl;
    cout << "--------------------" << endl;
}

int main(){
    vector<Student> students;
    string Action="Yes";
    
    while(Action != "No"){
        cout << "Would you like to add another student? (Yes/No) ";
        cin >> Action;
        if(Action == "Yes"){
            Student s = gatherStudentData();
            students.push_back(s);
        }else{
            break;
        }
        
    }
    for(Student s : students){
        printStudents(s);
    }
    
    return 0;
}
